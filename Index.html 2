// ── Sector allocation: $ amount invested per sector ──
// Default: $12,500 per sector × 8 = $100,000
// Each sector's stocks get equal share of that sector's allocation
const SECTOR_COLORS = ['#00d4ff','#00ffb3','#b94dff','#ffc832','#ff6b35','#ff3fa0','#3cf0ff','#8fff5a'];
const SECTOR_NAMES  = ['AI Infra','Nuclear','Semiconductors','Quantum','Cybersecurity','Robotics','Biotech','Clean Energy'];
let sectorAlloc = [12500,12500,12500,12500,12500,12500,12500,12500]; // $ per sector

// Compute per-stock investment given current sector allocation.
// A stock may appear in multiple sectors (e.g. NVDA in AI Infra + Semis + Quantum).
// Its total allocation = SUM of (sectorAlloc[i] / sector_size) for each sector it belongs to.
// This ensures Σ all stock investments = Σ sectorAlloc = $100,000 exactly.
function getStockInvestment(sym) {
  let total = 0;
  for (let i = 0; i < SECTOR_T.length; i++) {
    if (SECTOR_T[i].ss.includes(sym)) {
      total += sectorAlloc[i] / SECTOR_T[i].ss.length;
    }
  }
  return total;
}
function getTotalInvested() {
  return sectorAlloc.reduce((a, v) => a + v, 0);
}

// ── Sim fallback ──
function seededRand(seed, step) {
  const a = Math.sin(seed * 127.1 + step * 311.7) * 43758.5453;
  const b = Math.cos(seed * 269.5 + step * 183.3) * 43758.5453;
  return ((a - Math.floor(a)) + (b - Math.floor(b))) / 2;
}
function getVol(sym) {
  const sd = SDATA[sym];
  if (!sd) return 0.0015;
  return { LOW:0.0008, MED:0.0015, HIGH:0.0028, 'X-HIGH':0.0045 }[sd.risk] || 0.0015;
}
function simPrice(sym, base) {
  const vol  = getVol(sym);
  const seed = sym.split('').reduce((a,c,i) => a + c.charCodeAt(0)*(i+7), 1);
  const sec  = Math.floor((Date.now() - sessionStart) / 1000);
  if (sec === 0) return base;
  let p = base;
  for (let i = 0; i < sec; i++) {
    const r = seededRand(seed, i);
    p = p * (1 + (r - 0.5) * 2 * vol);
  }
  return Math.min(Math.max(p, base * 0.2), base * 3.0);
}

