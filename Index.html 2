<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>APEX CAPITAL — Investment Intelligence Dashboard v4</title>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Mono:wght@300;400;500&family=Outfit:wght@300;400;600;700;900&display=swap" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.0/chart.umd.min.js"></script>
<style>
:root{
  --bg:#020810;--p1:#060e1c;--p2:#0a1428;--p3:#0e1c35;
  --b1:rgba(0,200,255,0.1);--b2:rgba(0,200,255,0.22);
  --a1:#00d4ff;--a2:#00ffb3;--a3:#ff6b35;--a4:#b94dff;
  --gold:#ffc832;--red:#ff3d5a;--pink:#ff3fa0;--teal:#3cf0ff;--lime:#8fff5a;
  --text:#d8eeff;--m1:#3d6080;--m2:#6a90aa;
}
*{margin:0;padding:0;box-sizing:border-box;}
html{scroll-behavior:smooth;}
body{background:var(--bg);color:var(--text);font-family:'Outfit',sans-serif;overflow-x:hidden;}
body::before{content:'';position:fixed;inset:0;background-image:linear-gradient(rgba(0,200,255,0.022) 1px,transparent 1px),linear-gradient(90deg,rgba(0,200,255,0.022) 1px,transparent 1px);background-size:54px 54px;pointer-events:none;z-index:0;}
body::after{content:'';position:fixed;top:-40%;left:-40%;width:180%;height:180%;background:radial-gradient(ellipse at 12% 22%,rgba(0,200,255,0.05) 0%,transparent 50%),radial-gradient(ellipse at 88% 78%,rgba(185,77,255,0.04) 0%,transparent 50%);pointer-events:none;z-index:0;animation:abg 20s ease-in-out infinite alternate;}
@keyframes abg{0%{transform:translate(0,0)}100%{transform:translate(20px,-12px)}}
.w{position:relative;z-index:1;max-width:1800px;margin:0 auto;padding:0 22px 80px;}

/* TICKER */
#tickerWrap{position:sticky;top:0;z-index:100;background:rgba(2,8,16,0.97);border-bottom:1px solid var(--b2);backdrop-filter:blur(14px);overflow:hidden;height:34px;display:flex;align-items:center;}
#tickerInner{display:flex;align-items:center;white-space:nowrap;animation:scroll 90s linear infinite;}
#tickerInner:hover{animation-play-state:paused;}
.ti{display:inline-flex;align-items:center;gap:6px;padding:0 18px;font-family:'DM Mono',monospace;font-size:11px;border-right:1px solid var(--b1);}
.ti-sym{color:var(--a1);font-weight:500;cursor:pointer;transition:color 0.2s;}
.ti-sym:hover{color:var(--a2);text-decoration:underline;}
.ti-name{color:var(--m2);font-size:9.5px;}
.ti-price{color:var(--text);}
.ti-up{color:var(--a2);}.ti-dn{color:var(--red);}
.tl{font-family:'DM Mono',monospace;font-size:9px;color:var(--m1);letter-spacing:2px;padding:0 14px 0 8px;border-right:1px solid var(--b2);}
@keyframes scroll{0%{transform:translateX(0)}100%{transform:translateX(-50%)}}

/* HEADER */
header{padding:20px 0 16px;display:flex;align-items:center;justify-content:space-between;border-bottom:1px solid var(--b1);margin-bottom:18px;}
.logo{display:flex;align-items:center;gap:13px;}
.logo-icon{width:46px;height:46px;background:linear-gradient(135deg,var(--a1),var(--a2));border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:21px;animation:lp 3s ease-in-out infinite;}
@keyframes lp{0%,100%{box-shadow:0 0 20px rgba(0,212,255,0.35)}50%{box-shadow:0 0 44px rgba(0,212,255,0.62),0 0 66px rgba(0,255,179,0.15)}}
.logo-text{font-family:'Bebas Neue',sans-serif;font-size:32px;letter-spacing:5px;background:linear-gradient(90deg,var(--a1),var(--a2));-webkit-background-clip:text;-webkit-text-fill-color:transparent;}
.logo-sub{font-family:'DM Mono',monospace;font-size:10px;color:var(--m1);letter-spacing:3px;margin-top:1px;}
.hdr-r{display:flex;align-items:center;gap:18px;}
.live-badge{display:flex;align-items:center;gap:7px;font-family:'DM Mono',monospace;font-size:10px;color:var(--a2);letter-spacing:2px;}
.ld{width:7px;height:7px;background:var(--a2);border-radius:50%;animation:bl 1.4s ease-in-out infinite;box-shadow:0 0 8px var(--a2);}
@keyframes bl{0%,100%{opacity:1}50%{opacity:0.1}}
.dtag{font-family:'DM Mono',monospace;font-size:10px;color:var(--m1);border:1px solid var(--b1);padding:4px 12px;border-radius:5px;}

/* VERDICT */
.verdict{background:linear-gradient(135deg,rgba(0,212,255,0.07),rgba(0,255,179,0.04));border:1px solid rgba(0,255,179,0.2);border-radius:12px;padding:16px 22px;margin-bottom:18px;position:relative;}
.verdict::before{content:'';position:absolute;left:0;top:0;bottom:0;width:3px;background:linear-gradient(180deg,var(--a1),var(--a2));border-radius:3px 0 0 3px;}
.v-lbl{font-family:'Bebas Neue',sans-serif;font-size:11px;letter-spacing:4px;color:var(--a2);margin-bottom:5px;}
.v-body{font-size:12.5px;line-height:1.82;color:#88b2ca;}
.v-body strong{color:var(--a1);}

/* PORTFOLIO TRACKER */
#tracker{background:linear-gradient(135deg,var(--p1),var(--p2));border:1px solid var(--b2);border-radius:14px;padding:18px 22px;margin-bottom:18px;position:relative;overflow:hidden;}
#tracker::after{content:'';position:absolute;inset:0;background:linear-gradient(90deg,rgba(0,212,255,0.04),transparent,rgba(0,255,179,0.03));pointer-events:none;}
.tr-top{display:flex;align-items:center;justify-content:space-between;margin-bottom:14px;flex-wrap:wrap;gap:10px;}
.tr-info{display:flex;align-items:center;gap:14px;}
.tr-title{font-family:'Bebas Neue',sans-serif;font-size:19px;letter-spacing:3px;color:var(--a1);}
.tr-sub{font-family:'DM Mono',monospace;font-size:9px;color:var(--m2);letter-spacing:1.2px;margin-top:2px;}
.d0badge{font-family:'DM Mono',monospace;font-size:10px;background:rgba(0,212,255,0.12);color:var(--a1);border:1px solid rgba(0,212,255,0.3);padding:4px 12px;border-radius:4px;letter-spacing:1px;}
.rbtn{background:none;border:1px solid var(--b1);color:var(--m2);font-family:'DM Mono',monospace;font-size:9px;padding:4px 12px;border-radius:4px;cursor:pointer;letter-spacing:1px;transition:all 0.2s;}
.rbtn:hover{border-color:var(--a1);color:var(--a1);}
.tr-kpis{display:grid;grid-template-columns:repeat(6,1fr);gap:10px;margin-bottom:14px;}
.tk{background:rgba(0,0,0,0.3);border:1px solid var(--b1);border-radius:9px;padding:11px 13px;}
.tk-l{font-family:'DM Mono',monospace;font-size:9px;letter-spacing:1.5px;color:var(--m1);text-transform:uppercase;margin-bottom:4px;}
.tk-v{font-family:'Bebas Neue',sans-serif;font-size:24px;line-height:1;}
.tk-s{font-size:9.5px;color:var(--m2);margin-top:2px;}
.cc{color:var(--a1);}.cg{color:var(--a2);}.co{color:var(--gold);}.cp{color:var(--a4);}.cr{color:var(--red);}.cw{color:var(--a3);}
.rank-grid{display:grid;grid-template-columns:1fr 1fr 1fr;gap:12px;}
.rp{background:rgba(0,0,0,0.25);border:1px solid var(--b1);border-radius:9px;padding:13px 14px;}
.rp-t{font-family:'DM Mono',monospace;font-size:9px;letter-spacing:1.5px;color:var(--m2);text-transform:uppercase;margin-bottom:9px;padding-bottom:7px;border-bottom:1px solid var(--b1);}
.rrow{display:flex;align-items:center;gap:8px;padding:4px 6px;border-radius:5px;transition:background 0.2s;cursor:pointer;}
.rrow:hover{background:rgba(0,212,255,0.05);}
.rn{font-family:'Bebas Neue',sans-serif;font-size:15px;width:20px;text-align:center;}
.rname{font-size:11px;font-weight:600;flex:1;}
.rval{font-family:'DM Mono',monospace;font-size:11px;}
.rbw{width:55px;height:4px;background:rgba(255,255,255,0.06);border-radius:2px;overflow:hidden;}
.rb{height:100%;border-radius:2px;transition:width 1.4s ease;}
.r1{color:var(--gold);}.r2{color:var(--a1);}.r3{color:var(--a4);}.r4{color:var(--m2);}

/* KPI SECTOR CARDS */
.kpi-row{display:grid;grid-template-columns:repeat(8,1fr);gap:10px;margin-bottom:16px;}
.kpi{background:var(--p1);border:1px solid var(--b1);border-radius:9px;padding:12px 13px;cursor:pointer;position:relative;overflow:hidden;opacity:0;animation:fu 0.5s ease forwards;transition:transform 0.2s,border-color 0.2s,box-shadow 0.2s;}
.kpi::after{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:var(--kc,var(--a1));}
.kpi:hover,.kpi.active{transform:translateY(-3px);border-color:var(--kc,var(--a1));box-shadow:0 0 16px color-mix(in srgb,var(--kc,var(--a1)) 28%,transparent);}
.kpi-l{font-family:'DM Mono',monospace;font-size:9px;letter-spacing:1.5px;color:var(--m1);text-transform:uppercase;margin-bottom:4px;}
.kpi-v{font-family:'Bebas Neue',sans-serif;font-size:23px;line-height:1;color:var(--kc,var(--a1));margin-bottom:2px;}
.kpi-s{font-size:9px;color:var(--m2);}
.kpi-h{position:absolute;bottom:6px;right:8px;font-family:'DM Mono',monospace;font-size:8px;color:var(--m1);}
.k1{--kc:var(--a1);}.k2{--kc:var(--a2);}.k3{--kc:var(--a4);}.k4{--kc:var(--gold);}.k5{--kc:var(--a3);}.k6{--kc:var(--pink);}.k7{--kc:var(--teal);}.k8{--kc:var(--lime);}
@keyframes fu{from{opacity:0;transform:translateY(16px)}to{opacity:1;transform:translateY(0)}}
.kpi:nth-child(1){animation-delay:.04s}.kpi:nth-child(2){animation-delay:.08s}.kpi:nth-child(3){animation-delay:.12s}.kpi:nth-child(4){animation-delay:.16s}.kpi:nth-child(5){animation-delay:.20s}.kpi:nth-child(6){animation-delay:.24s}.kpi:nth-child(7){animation-delay:.28s}.kpi:nth-child(8){animation-delay:.32s}

/* SECTOR PANEL */
#sp{display:none;background:var(--p1);border:1px solid var(--b2);border-radius:14px;margin-bottom:18px;overflow:hidden;}
#sp.on{display:block;animation:fu 0.3s ease forwards;}
.sp-hdr{display:flex;align-items:flex-start;justify-content:space-between;padding:15px 20px 12px;border-bottom:1px solid var(--b1);}
.sp-title{font-family:'Bebas Neue',sans-serif;font-size:20px;letter-spacing:3px;margin-bottom:5px;}
.sp-meta{display:flex;gap:8px;flex-wrap:wrap;}
.sp-badge{font-family:'DM Mono',monospace;font-size:10px;padding:3px 10px;border-radius:4px;letter-spacing:1px;}
.sp-close{background:none;border:1px solid var(--b1);color:var(--m2);font-size:10px;padding:5px 12px;border-radius:5px;cursor:pointer;font-family:'DM Mono',monospace;letter-spacing:1px;transition:all 0.2s;white-space:nowrap;}
.sp-close:hover{border-color:var(--a1);color:var(--a1);}
.sp-body{display:grid;grid-template-columns:1fr 370px;}
.sp-tbl{padding:13px 16px;overflow-x:auto;}
.sp-charts{border-left:1px solid var(--b1);padding:13px 15px;display:flex;flex-direction:column;gap:13px;}
table{width:100%;border-collapse:collapse;}
th{font-family:'DM Mono',monospace;font-size:9px;letter-spacing:1.5px;color:var(--m1);text-transform:uppercase;padding:7px 9px;text-align:left;border-bottom:1px solid var(--b1);}
td{padding:7px 9px;font-size:11.5px;border-bottom:1px solid rgba(0,200,255,0.04);vertical-align:middle;}
tr:hover td{background:rgba(0,200,255,0.03);}
.tsym{font-family:'DM Mono',monospace;font-weight:500;font-size:12px;color:var(--a1);cursor:pointer;text-decoration:underline dotted;transition:color 0.15s;}
.tsym:hover{color:var(--a2);}
.tnm{font-weight:600;font-size:11.5px;}
.tcat{font-size:10px;color:var(--m2);max-width:220px;}
.tag{display:inline-block;padding:2px 7px;border-radius:3px;font-family:'DM Mono',monospace;font-size:9.5px;font-weight:500;}
.up{background:rgba(0,255,179,0.11);color:var(--a2);}.dn{background:rgba(255,61,90,0.11);color:var(--red);}
.rl{background:rgba(0,255,179,0.1);color:var(--a2);}.rm{background:rgba(255,200,50,0.1);color:var(--gold);}.rh{background:rgba(255,107,53,0.11);color:var(--a3);}.rx{background:rgba(255,61,90,0.11);color:var(--red);}
.cvb{font-family:'Bebas Neue',sans-serif;font-size:13px;}
.c5{color:var(--a2);}.c4{color:var(--a1);}.c3{color:var(--gold);}.c2{color:var(--a3);}.c1{color:var(--red);}
.tg12{font-family:'DM Mono',monospace;font-size:11px;color:var(--a2);}
.tg24{font-family:'DM Mono',monospace;font-size:11px;color:var(--a1);}
.ch-t{font-family:'DM Mono',monospace;font-size:9px;letter-spacing:1.5px;color:var(--m1);text-transform:uppercase;margin-bottom:7px;}
.ch-b{position:relative;height:130px;}

/* ===== STOCK MODAL ===== */
#modal{display:none;position:fixed;inset:0;z-index:2000;background:rgba(2,8,16,0.94);backdrop-filter:blur(18px);overflow-y:auto;}
#modal.open{display:flex;align-items:flex-start;justify-content:center;padding:30px 20px;}
.mcard{background:var(--p1);border:1px solid var(--b2);border-radius:18px;width:100%;max-width:1060px;overflow:hidden;animation:msl 0.35s cubic-bezier(0.34,1.56,0.64,1);}
@keyframes msl{from{transform:translateY(30px);opacity:0}to{transform:translateY(0);opacity:1}}
.mhdr{display:flex;align-items:flex-start;justify-content:space-between;padding:22px 28px 16px;border-bottom:1px solid var(--b1);background:linear-gradient(135deg,var(--p2),var(--p1));}
.mhl{display:flex;gap:16px;align-items:flex-start;}
.mbadge{width:54px;height:54px;border-radius:12px;display:flex;align-items:center;justify-content:center;font-family:'Bebas Neue',sans-serif;font-size:13px;letter-spacing:1px;flex-shrink:0;}
.mtitle{font-family:'Bebas Neue',sans-serif;font-size:28px;letter-spacing:2px;line-height:1;margin-bottom:3px;}
.msector{font-family:'DM Mono',monospace;font-size:10px;color:var(--m2);letter-spacing:2px;text-transform:uppercase;margin-bottom:8px;}
.mtags{display:flex;gap:7px;flex-wrap:wrap;}
.mtag{font-family:'DM Mono',monospace;font-size:10px;padding:3px 10px;border-radius:4px;border:1px solid;}
.mcx{background:none;border:1px solid var(--b1);color:var(--m2);font-size:16px;width:34px;height:34px;border-radius:8px;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all 0.2s;flex-shrink:0;}
.mcx:hover{border-color:var(--a1);color:var(--a1);}
.mbody{padding:22px 28px;}

/* price KPIs */
.prow{display:grid;grid-template-columns:repeat(5,1fr);gap:10px;margin-bottom:18px;}
.pcard{background:var(--p2);border:1px solid var(--b1);border-radius:10px;padding:12px 14px;text-align:center;}
.pc-l{font-family:'DM Mono',monospace;font-size:9px;letter-spacing:1.5px;color:var(--m1);text-transform:uppercase;margin-bottom:4px;}
.pc-v{font-family:'Bebas Neue',sans-serif;font-size:24px;line-height:1;}
.pc-s{font-size:10px;color:var(--m2);margin-top:3px;}

/* chart tabs */
.ctabs{display:flex;gap:4px;margin-bottom:10px;}
.ct{font-family:'DM Mono',monospace;font-size:10px;letter-spacing:1.5px;text-transform:uppercase;padding:5px 14px;border:1px solid var(--b1);border-radius:5px;cursor:pointer;color:var(--m2);background:none;transition:all 0.2s;}
.ct:hover{color:var(--text);}
.ct.act{color:var(--a1);border-color:rgba(0,212,255,0.4);background:rgba(0,212,255,0.08);}
.chartarea{position:relative;height:190px;background:var(--p2);border:1px solid var(--b1);border-radius:10px;padding:12px;margin-bottom:18px;}

/* targets */
.trow{display:grid;grid-template-columns:repeat(4,1fr);gap:10px;margin-bottom:18px;}
.tcard{background:var(--p2);border-radius:10px;padding:12px;text-align:center;border:1px solid var(--b1);}
.tc-l{font-family:'DM Mono',monospace;font-size:9px;letter-spacing:1px;color:var(--m1);text-transform:uppercase;margin-bottom:4px;}
.tc-v{font-family:'Bebas Neue',sans-serif;font-size:25px;}
.tc-s{font-size:10px;color:var(--m2);margin-top:2px;}

/* analysis */
.agrid{display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-bottom:18px;}
.apanel{background:var(--p2);border:1px solid var(--b1);border-radius:10px;padding:15px;}
.apt{font-family:'Bebas Neue',sans-serif;font-size:14px;letter-spacing:2px;margin-bottom:10px;padding-bottom:8px;border-bottom:1px solid var(--b1);}
.fgrid{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:12px;}
.fi{background:rgba(0,0,0,0.2);border-radius:6px;padding:8px 10px;}
.fi-l{font-family:'DM Mono',monospace;font-size:9px;letter-spacing:1px;color:var(--m1);text-transform:uppercase;margin-bottom:3px;}
.fi-v{font-family:'Bebas Neue',sans-serif;font-size:18px;line-height:1;}
.outlook{font-size:11.5px;line-height:1.78;color:#7aafcc;}
.bbgrid{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-top:10px;}
.bull{background:rgba(0,255,179,0.07);border:1px solid rgba(0,255,179,0.2);border-radius:7px;padding:10px 12px;}
.bear{background:rgba(255,61,90,0.07);border:1px solid rgba(255,61,90,0.18);border-radius:7px;padding:10px 12px;}
.bb-t{font-family:'Bebas Neue',sans-serif;font-size:12px;letter-spacing:2px;margin-bottom:6px;}
.bull .bb-t{color:var(--a2);}.bear .bb-t{color:var(--red);}
.bbi{font-size:11px;color:var(--m2);margin-bottom:4px;padding-left:10px;position:relative;}
.bbi::before{content:'•';position:absolute;left:0;}
.bull .bbi::before{color:var(--a2);}.bear .bbi::before{color:var(--red);}

/* citations */
.citbox{background:var(--p2);border:1px solid var(--b1);border-radius:10px;padding:15px;}
.cit-t{font-family:'Bebas Neue',sans-serif;font-size:14px;letter-spacing:2px;margin-bottom:12px;color:var(--a1);}
.citgrid{display:grid;grid-template-columns:1fr 1fr;gap:8px;}
.cititem{background:rgba(0,0,0,0.2);border:1px solid var(--b1);border-radius:7px;padding:10px 12px;display:flex;gap:8px;transition:border-color 0.2s;}
.cititem:hover{border-color:var(--b2);}
.citicon{font-size:14px;flex-shrink:0;margin-top:1px;}
.citsrc{font-family:'DM Mono',monospace;font-size:9px;letter-spacing:1px;color:var(--a1);text-transform:uppercase;margin-bottom:2px;}
.citdesc{font-size:11px;color:var(--m2);line-height:1.5;margin-bottom:4px;}
.citlink{font-family:'DM Mono',monospace;font-size:9px;color:var(--a4);text-decoration:none;}
.citlink:hover{text-decoration:underline;color:var(--a2);}

/* IPO */
#ipo{background:linear-gradient(135deg,var(--p1),rgba(10,20,40,0.9));border:1px solid rgba(185,77,255,0.25);border-radius:14px;padding:20px 22px;margin-bottom:18px;position:relative;overflow:hidden;}
#ipo::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:linear-gradient(90deg,var(--a4),var(--pink),var(--gold));}
.ipo-hdr{display:flex;align-items:center;justify-content:space-between;margin-bottom:14px;}
.ipo-title{font-family:'Bebas Neue',sans-serif;font-size:19px;letter-spacing:3px;color:var(--a4);}
.ipo-sub{font-family:'DM Mono',monospace;font-size:9px;color:var(--m2);letter-spacing:1.5px;margin-top:3px;}
.ipo-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:11px;}
.icard{background:rgba(0,0,0,0.35);border:1px solid rgba(185,77,255,0.18);border-radius:10px;padding:14px;transition:all 0.22s;position:relative;overflow:hidden;}
.icard:hover{border-color:rgba(185,77,255,0.42);transform:translateY(-2px);box-shadow:0 0 18px rgba(185,77,255,0.14);}
.icard::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:var(--ic,var(--a4));}
.ico{font-family:'Bebas Neue',sans-serif;font-size:17px;letter-spacing:1px;margin-bottom:2px;}
.isect{font-family:'DM Mono',monospace;font-size:9px;color:var(--m2);letter-spacing:1.5px;text-transform:uppercase;margin-bottom:8px;}
.ival{font-family:'Bebas Neue',sans-serif;font-size:19px;color:var(--ic,var(--a4));}
.ilvl{font-family:'DM Mono',monospace;font-size:9px;color:var(--m1);letter-spacing:1px;margin-bottom:8px;}
.irow{display:flex;align-items:center;justify-content:space-between;margin-bottom:7px;}
.iwhen{font-family:'DM Mono',monospace;font-size:10px;padding:2px 8px;border-radius:3px;background:rgba(185,77,255,0.12);color:var(--a4);border:1px solid rgba(185,77,255,0.25);}
.iprob{font-family:'DM Mono',monospace;font-size:10px;color:var(--gold);}
.idesc{font-size:11px;line-height:1.62;color:#507080;}
.ihype{position:absolute;top:10px;right:10px;font-size:15px;}

/* TABS */
