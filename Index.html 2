// ── REST batch quote — ONLY updates lastPrices, NEVER basePrices after baseSet ──
async function fetchAllQuotes() {
  const batchSize = 20;
  let gotAny = false;
  const syms = TICKERS.map(t => t.s);
  for (let i = 0; i < syms.length; i += batchSize) {
    const batch = syms.slice(i, i + batchSize);
    await Promise.allSettled(batch.map(async sym => {
      try {
        const res = await fetch(`${FINNHUB_REST}/quote?symbol=${sym}&token=${FINNHUB_KEY}`);
        if (!res.ok) return;
        const d = await res.json();
        if (d && d.c && d.c > 0) {
          lastPrices[sym] = d.c;
          gotAny = true;
        }
      } catch(e) {}
    }));
    if (i + batchSize < syms.length) await new Promise(r => setTimeout(r, 250));
  }
  if (gotAny) { window._lastUpdate=Date.now(); setLiveStatus('delayed'); buildTicker(); updateTracker(); }
  return gotAny;
}

// ── WebSocket ──
function connectWebSocket() {
  if (fhSocket) { try { fhSocket.close(); } catch(e) {} }
  fhSocket = new WebSocket(`${FINNHUB_WS}?token=${FINNHUB_KEY}`);
  fhSocket.addEventListener('open', () => {
    wsReady = true;
    TICKERS.forEach(t => fhSocket.send(JSON.stringify({ type:'subscribe', symbol:t.s })));
    setLiveStatus('live');
    if (simInterval) { clearInterval(simInterval); simInterval = null; }
  });
  fhSocket.addEventListener('message', e => {
    try {
      const msg = JSON.parse(e.data);
      if (msg.type === 'trade' && msg.data) {
        msg.data.forEach(tr => {
          if (tr.s && tr.p > 0 && tr.s in lastPrices) lastPrices[tr.s] = tr.p;
        });
        window._lastUpdate = Date.now();
        buildTicker(); updateTracker();
        if (mSym && document.getElementById('modal').classList.contains('open')) updateModalPrices();
      }
    } catch(e) {}
  });
  fhSocket.addEventListener('close', () => { wsReady=false; setLiveStatus('delayed'); setTimeout(connectWebSocket,5000); });
  fhSocket.addEventListener('error', () => { wsReady=false; setLiveStatus('delayed'); });
}

// ── Sim tick — runs only when market closed ──
