function ccls(cv){const n=(cv.match(/★/g)||[]).length;return n>=5?'c5':n>=4?'c4':n>=3?'c3':n>=2?'c2':'c1';}
function rcls(r){return r==='LOW'?'rl':r==='MED'?'rm':r==='HIGH'?'rh':'rx';}
function openSec(idx){
  if(activeSec===idx){closeSec();return;}
  activeSec=idx;const s=SD[idx];
  document.querySelectorAll('.kpi').forEach(k=>k.classList.remove('active'));
  document.getElementById('kpi-'+idx).classList.add('active');
  document.getElementById('sp-title').textContent=s.nm;
  document.getElementById('sp-title').style.color=s.col;
  ['sb1','sb2','sb3'].forEach((id,i)=>{
    const el=document.getElementById(id);el.textContent=[s.b1,s.b2,s.b3][i];
    el.style.cssText=`background:${s.col}18;color:${s.col};border:1px solid ${s.col}44;border-radius:4px;padding:3px 10px;`;
  });
  _modalSectorStocks = s.cos.map(c=>c.t);  // track tickers for modal nav
  const tb=document.getElementById('sptb');tb.innerHTML='';
  s.cos.forEach(c=>{
    const rcl=c.ret.startsWith('+')?'up':c.ret.startsWith('-')?'dn':'up';
    const tr=document.createElement('tr');
    tr.innerHTML=`<td><span class="tsym" onclick="openStock('${c.t}')">${c.t} ↗</span></td><td class="tnm">${c.n}</td><td><span class="cvb ${ccls(c.cv)}">${c.cv}</span></td><td><span class="tag ${rcls(c.r)}">${c.r}</span></td><td class="tg12">+${c.t12}%</td><td class="tg24">+${c.t24}%</td><td><span class="tag ${rcl}">${c.ret}</span></td><td class="tcat">${c.cat}</td>`;
    tb.appendChild(tr);
  });
  if(cb1){cb1.destroy();cb1=null;}if(cb2){cb2.destroy();cb2=null;}
  const labels=s.cos.map(c=>c.t);
  cb1=new Chart(document.getElementById('cb1').getContext('2d'),{type:'bar',data:{labels,datasets:[{data:s.cos.map(c=>c.t12),backgroundColor:s.col+'bb',borderRadius:3,borderSkipped:false}]},options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{display:false},tooltip:{callbacks:{label:c=>`+${c.raw}%`},backgroundColor:'#060e1c'}},scales:{x:{grid:{display:false},ticks:{font:{size:9}}},y:{grid:{color:'rgba(0,200,255,0.05)'},ticks:{callback:v=>`+${v}%`,font:{size:9}}}}}});
  cb2=new Chart(document.getElementById('cb2').getContext('2d'),{type:'bar',data:{labels,datasets:[{data:s.cos.map(c=>c.t24),backgroundColor:s.col+'77',borderRadius:3,borderSkipped:false}]},options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{display:false},tooltip:{callbacks:{label:c=>`+${c.raw}%`},backgroundColor:'#060e1c'}},scales:{x:{grid:{display:false},ticks:{font:{size:9}}},y:{grid:{color:'rgba(0,200,255,0.05)'},ticks:{callback:v=>`+${v}%`,font:{size:9}}}}}});
  const spEl=document.getElementById('sp');spEl.classList.add('on');
  setTimeout(()=>spEl.scrollIntoView({behavior:'smooth',block:'nearest'}),50);
}
function closeSec(){activeSec=null;document.querySelectorAll('.kpi').forEach(k=>k.classList.remove('active'));document.getElementById('sp').classList.remove('on');}

