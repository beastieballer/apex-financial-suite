// ── Animated number counter ──
function animateVal(el, end, prefix, suffix, decimals) {
  prefix  = prefix  || '';
  suffix  = suffix  || '';
  decimals = decimals != null ? decimals : 2;
  const startTxt = el.textContent.replace(/[^0-9.-]/g, '');
  const start = parseFloat(startTxt) || 0;
  if (Math.abs(end - start) < 0.01) { el.textContent = prefix + end.toFixed(decimals) + suffix; return; }
  const dur = 900, t0 = performance.now();
  const tick = function(t) {
    const p = Math.min((t - t0) / dur, 1);
    const e = p < 0.5 ? 2 * p * p : 1 - Math.pow(-2 * p + 2, 2) / 2; // ease-in-out
    el.textContent = prefix + (start + (end - start) * e).toFixed(decimals) + suffix;
    if (p < 1) requestAnimationFrame(tick);
  };
  requestAnimationFrame(tick);
}

// ── Portfolio Tracker ──
// P&L = Σ [ (sectorAlloc[i]/10) × (livePrice/basePrice) ] − totalInvested
// basePrices locked at reset → always starts at exactly $0 P&L
function updateTracker() {
  const totalInvested = getTotalInvested();

  // Build per-stock perf
  const perf = TICKERS.map(t => {
    const cur       = lastPrices[t.s]  || t.b;
    const base      = basePrices[t.s]  || t.b;
    const inv       = getStockInvestment(t.s);  // $ allocated to this stock
    const pct       = base > 0 ? ((cur - base) / base) * 100 : 0;
    const val       = base > 0 ? inv * (cur / base) : inv;
    return { s:t.s, cur, base, pct, inv, val };
  });

  // Only include stocks that have allocation (inv > 0)
  const active     = perf.filter(x => x.inv > 0);
  const totalVal   = active.reduce((a, x) => a + x.val, 0);
  const totalRet   = totalVal - totalInvested;
  const totalPct   = totalInvested > 0 ? (totalRet / totalInvested) * 100 : 0;

  // Portfolio Value KPI — animated counter
  const tvEl = document.getElementById('tv');
  animateVal(tvEl, totalVal, '$', '', 2);

  // P&L KPI — animated counter
  const plEl = document.getElementById('tpl');
  plEl.className = 'tk-v ' + (totalRet >= 0 ? 'cg' : 'cr');
  animateVal(plEl, Math.abs(totalRet), totalRet >= 0 ? '+$' : '-$', '', 2);

  // % + mode labels
  document.getElementById('tpct').textContent =
    (totalPct >= 0 ? '+' : '') + totalPct.toFixed(3) + '% total return';
  document.getElementById('tmode').textContent = liveMode ? '● Finnhub Live' : '○ Simulated';
  document.getElementById('ttime').textContent =
    new Date().toLocaleTimeString('en-US', {hour:'2-digit', minute:'2-digit', second:'2-digit'});

  // Sector performance (only active/allocated sectors)
  const sp = SECTOR_T.map((s, idx) => {
    if (sectorAlloc[idx] === 0) return null;
    const stocks = perf.filter(x => s.ss.includes(x.s) && x.inv > 0);
    const avg    = stocks.length ? stocks.reduce((a,x)=>a+x.pct,0)/stocks.length : 0;
    return { n:s.n, c:s.c, avg };
  }).filter(Boolean).sort((a,b) => b.avg - a.avg);

  if (sp.length > 0) {
    document.getElementById('tbs').textContent  = sp[0].n;
    document.getElementById('tbsv').textContent = (sp[0].avg>=0?'+':'')+sp[0].avg.toFixed(3)+'% avg';
    document.getElementById('tws').textContent  = sp[sp.length-1].n;
    document.getElementById('twsv').textContent = (sp[sp.length-1].avg>=0?'+':'')+sp[sp.length-1].avg.toFixed(3)+'% avg';
  }

  // Best stock
  const activeSorted = [...active].sort((a,b)=>b.pct-a.pct);
  if (activeSorted.length > 0) {
    document.getElementById('tbst').textContent  = activeSorted[0].s;
    document.getElementById('tbstv').textContent = (activeSorted[0].pct>=0?'+':'')+activeSorted[0].pct.toFixed(3)+'%';
  }

  // Sector ranking bars
  const maxAbs = Math.max(...sp.map(x=>Math.abs(x.avg)), 0.001);
  const sr = document.getElementById('secRank'); sr.innerHTML = '';
  sp.forEach((s, i) => {
    const rc = i===0?'r1':i===1?'r2':i===2?'r3':'r4';
    const bw = Math.min(100, Math.abs(s.avg)/maxAbs*100);
    sr.innerHTML +=
      `<div class="rrow"><span class="rn ${rc}">${i+1}</span><span class="rname">${s.n}</span>` +
      `<div class="rbw"><div class="rb" style="width:${bw}%;background:${s.c};"></div></div>` +
      `<span class="rval" style="color:${s.avg>=0?'var(--a2)':'var(--red)'};">${s.avg>=0?'+':''}${s.avg.toFixed(3)}%</span></div>`;
  });

  // Top 10 movers (all 80 portfolio stocks, sorted by % change)
  const allSorted = [...perf].sort((a,b) => b.pct - a.pct);
  const ts = document.getElementById('topStks'); ts.innerHTML = '';
  allSorted.slice(0, 10).forEach((s, i) => {
    const rc   = i===0?'r1':i===1?'r2':i===2?'r3':'r4';
    const name = TICKER_NAMES[s.s] || s.s;
    ts.innerHTML +=
      `<div class="rrow" onclick="openStock('${s.s}')">` +
      `<span class="rn ${rc}">${i+1}</span>` +
      `<span class="rname" style="font-family:'DM Mono',monospace;font-size:10px;">${s.s} <span style="color:var(--m2);font-size:9px;">${name}</span></span>` +
      `<span class="rval" style="color:${s.pct>=0?'var(--a2)':'var(--red)'};">${s.pct>=0?'+':''}${s.pct.toFixed(2)}%</span>` +
      `</div>`;
  });

  // Bottom 5
  const bs = document.getElementById('botStks'); bs.innerHTML = '';
  allSorted.slice(-5).reverse().forEach((s, i) => {
    const name = TICKER_NAMES[s.s] || s.s;
    bs.innerHTML +=
      `<div class="rrow" onclick="openStock('${s.s}')">` +
      `<span class="rn" style="color:var(--red);font-family:'Bebas Neue',sans-serif;font-size:15px;width:20px;text-align:center;">${i+1}</span>` +
      `<span class="rname" style="font-family:'DM Mono',monospace;font-size:10px;">${s.s} <span style="color:var(--m2);font-size:9px;">${name}</span></span>` +
      `<span class="rval" style="color:var(--red);">${s.pct.toFixed(2)}%</span>` +
      `</div>`;
  });
}

// ── RESET — snapshot current live prices as new Day 0 cost basis ──
// basePrices = lastPrices at moment of reset → P&L starts at exactly $0
function resetPortfolio() {
  sessionStart = Date.now();
  lockBasePrices();  // snapshot current live prices → P&L = $0 exactly
  const dateStr = new Date().toLocaleDateString('en-US',{month:'short',day:'numeric',year:'numeric'}).toUpperCase();
  document.getElementById('d0badge').textContent = '◉ DAY 0 — ' + dateStr;

  // Restart sim loop so prices drift from the new baseline
  if (!liveMode) {
    if (simInterval) clearInterval(simInterval);
    simInterval = setInterval(simTick, 1000);
  }

  updateTracker();

  // Re-fetch REST quotes in background to refresh lastPrices
  fetchAllQuotes().then(got => {
    if (got) lockBasePrices(); // re-lock again to real prices after fetch
  });
}

// ── SECTOR ALLOCATION EDITOR ──
function toggleAllocEditor() {
  const ed = document.getElementById('allocEditor');
  if (ed.style.display === 'none') {
    buildAllocEditor();
    ed.style.display = 'block';
  } else {
    ed.style.display = 'none';
  }
}

function buildAllocEditor() {
  const container = document.getElementById('allocSliders');
  container.innerHTML = '';

  // Inject per-slider thumb colors as a style block (works on all desktop browsers)
  let styleBlock = '<style id="allocSliderStyle">';
  SECTOR_COLORS.forEach((color, i) => {
    styleBlock += `#ar${i}::-webkit-slider-thumb{background:${color};}`;
    styleBlock += `#ar${i}::-moz-range-thumb{background:${color};}`;
    styleBlock += `#ar${i}{background:linear-gradient(to right,${color}66 0%,${color}66 ${sectorAlloc[i]/500}%,rgba(255,255,255,0.08) ${sectorAlloc[i]/500}%,rgba(255,255,255,0.08) 100%);}`;
  });
  styleBlock += '</style>';
  const existing = document.getElementById('allocSliderStyle');
  if (existing) existing.remove();
  document.head.insertAdjacentHTML('beforeend', styleBlock);

  SECTOR_NAMES.forEach((name, i) => {
    const color   = SECTOR_COLORS[i];
    const val     = sectorAlloc[i];
    const perStock = (val / 10).toFixed(0);
    container.innerHTML +=
      `<div style="background:rgba(0,0,0,0.25);border:1px solid ${color}44;border-radius:8px;padding:10px 12px;">` +
        `<div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:8px;">` +
          `<span style="font-family:'DM Mono',monospace;font-size:10px;color:${color};letter-spacing:1px;font-weight:600;">${name.toUpperCase()}</span>` +
          `<div style="display:flex;align-items:center;gap:8px;">` +
            `<span style="font-family:'DM Mono',monospace;font-size:9px;color:var(--m2);">$<span id="av${i}">${perStock}</span>/stock</span>` +
            `<input type="number" id="ai${i}" min="0" max="100000" step="500" value="${val}"` +
              ` oninput="onAllocInput(${i})"` +
              ` style="width:80px;background:rgba(0,0,0,0.4);border:1px solid ${color}88;color:${color};` +
              `font-family:'DM Mono',monospace;font-size:11px;padding:4px 6px;border-radius:4px;text-align:right;outline:none;" />` +
          `</div>` +
        `</div>` +
        `<input type="range" id="ar${i}" min="0" max="50000" step="500" value="${val}"` +
          ` oninput="onAllocSlider(${i})" style="width:100%;" />` +
      `</div>`;
  });
  refreshAllocTotals();
}

function updateSliderStyle(i) {
  const color = SECTOR_COLORS[i];
  const val   = sectorAlloc[i];
  const pct   = (val / 50000) * 100;
  const sl    = document.getElementById('ar'+i);
  if (sl) sl.style.background = `linear-gradient(to right,${color}88 0%,${color}88 ${pct}%,rgba(255,255,255,0.08) ${pct}%,rgba(255,255,255,0.08) 100%)`;
  // also update thumb color in style block
  const st = document.getElementById('allocSliderStyle');
  if (st) {
    // Rebuild full style block
    let s = '<style id="allocSliderStyle">';
    SECTOR_COLORS.forEach((c, j) => {
      s += `#ar${j}::-webkit-slider-thumb{background:${c};}`;
      s += `#ar${j}::-moz-range-thumb{background:${c};}`;
    });
    s += '</style>';
    st.outerHTML = s;
  }
}

function onAllocInput(i) {
  const num = parseFloat(document.getElementById('ai'+i).value) || 0;
  sectorAlloc[i] = Math.max(0, Math.min(100000, num));
  const sl = document.getElementById('ar'+i);
  if (sl) sl.value = sectorAlloc[i];
  const pp = document.getElementById('av'+i);
  if (pp) pp.textContent = (sectorAlloc[i]/10).toFixed(0);
  updateSliderStyle(i);
  refreshAllocTotals();
}

function onAllocSlider(i) {
  const val = parseFloat(document.getElementById('ar'+i).value) || 0;
  sectorAlloc[i] = val;
  const inp = document.getElementById('ai'+i);
  if (inp) inp.value = val;
  const pp = document.getElementById('av'+i);
  if (pp) pp.textContent = (val/10).toFixed(0);
  updateSliderStyle(i);
  refreshAllocTotals();
}

function refreshAllocTotals() {
  const total   = getTotalInvested();
  const remain  = 100000 - total;
  const remEl   = document.getElementById('allocRemain');
  const totEl   = document.getElementById('allocTotal');
  if (remEl) { remEl.textContent = '$' + Math.abs(remain).toLocaleString(); remEl.style.color = remain < 0 ? 'var(--red)' : remain === 0 ? 'var(--a2)' : 'var(--gold)'; }
  if (totEl) { totEl.textContent = '$' + total.toLocaleString(); totEl.style.color = total === 100000 ? 'var(--a2)' : total > 100000 ? 'var(--red)' : 'var(--gold)'; }
}

function equalizeAlloc() {
  const eq = Math.round(100000 / 8 / 500) * 500;
  sectorAlloc = Array(8).fill(eq);
  buildAllocEditor();
}
// Preset allocations — index order: AI Infra, Nuclear, Semis, Quantum, Cyber, Robotics, Biotech, Clean Energy
function setAllocPreset(type) {
  if (type === 'growth') {
    // Growth Focus: AI-heavy, high-risk tilt
    sectorAlloc = [25000, 12000, 18000, 8000, 15000, 8000, 7000, 7000];
  } else if (type === 'cons') {
    // Conservative: income + stable sectors, lighter on speculative
    sectorAlloc = [20000, 22000, 18000, 2000, 12000, 7000, 4000, 15000];
  }
  buildAllocEditor();
}

function clearAlloc() {
  sectorAlloc = Array(8).fill(0);
  buildAllocEditor();
}

function applyAlloc() {
  // Warn if over-allocated
  const total = getTotalInvested();
  if (total > 100000) {
    alert(`Total allocation $${total.toLocaleString()} exceeds $100,000. Please reduce before applying.`);
    return;
  }
  // Update subtitle
  const active = sectorAlloc.filter(v=>v>0).length;
  document.getElementById('tr-sub').textContent =
    `${active} SECTORS · $${total.toLocaleString()} DEPLOYED · DAY 0 RESET APPLIED`;
  // Close editor, reset P&L with new allocation
  document.getElementById('allocEditor').style.display = 'none';
  resetPortfolio();
}

// ── Last-updated badge (dynamic "Updated Xs ago") ──
window._lastUpdate = Date.now();
function refreshUpdBadge() {
  const el = document.getElementById('updBadge');
  if (!el) return;
  const secs = Math.round((Date.now() - window._lastUpdate) / 1000);
  let txt, color, border;
  if (secs < 30) {
    txt = secs <= 3 ? 'LIVE NOW' : 'UPDATED ' + secs + 's AGO';
    color = 'var(--a2)'; border = 'rgba(0,255,179,0.3)';
  } else if (secs < 120) {
    txt = 'UPDATED ' + secs + 's AGO';
    color = 'var(--gold)'; border = 'rgba(255,200,50,0.3)';
  } else {
    const m = Math.round(secs / 60);
    txt = 'UPDATED ' + m + 'm AGO';
    color = 'var(--m2)'; border = 'var(--b1)';
  }
  el.textContent = txt;
  el.style.color = color;
  el.style.borderColor = border;
}
setInterval(refreshUpdBadge, 5000);
refreshUpdBadge();

