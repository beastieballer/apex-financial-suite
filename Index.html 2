  if (!cfg) return { data: [base], labels: [''] };

  const cur  = lastPrices[sym] || base;
  const vol  = getVol(sym);
  const seed = sym.split('').reduce((a, c, i) => a + c.charCodeAt(0) * (i + 7), 1);
  const now  = Date.now();

  // Volatility scales up for longer timeframes
  const volScale  = { '1D':1, '7D':3, '1M':5, '1Y':14 }[period] || 1;
  const scaledVol = vol * volScale;

  // Start slightly before current price so chart shows realistic history
  const startOffset = { '1D':0.995, '7D':0.96, '1M':0.92, '1Y':0.72 }[period] || 0.98;
  let price = cur * startOffset;

  const raw = [];
  for (let i = 0; i < cfg.candles; i++) {
    const r = seededRand(seed + period.charCodeAt(0) * 17, i);
    price = price * (1 + (r - 0.5) * 2 * scaledVol);
    raw.push(price);
  }

  // Taper-scale so chart ends exactly at current live price
  const lastRaw = raw[raw.length - 1];
  const scale   = cur / lastRaw;
  const data    = raw.map((p, i) => {
    const taper = i / raw.length;
    return +( p * (1 + (scale - 1) * taper) ).toFixed(2);
  });

  const labels = data.map((_, i) => (i % cfg.labelEvery === 0) ? cfg.fmt(i, now) : '');
  return { data, labels };
}

async function renderMChart(sym, base, period) {
  if (mChart) { mChart.destroy(); mChart = null; }

  // Show loading state
  const ctx = document.getElementById('mchart').getContext('2d');
  ctx.clearRect(0, 0, ctx.canvas.width, ctx.canvas.height);

  let data, labels;

  // For 1D: fetch real intraday candles from Finnhub
  if (period === '1D') {
    try {
      const now   = Math.floor(Date.now() / 1000);
      const from  = now - 23400; // 6.5 trading hours in seconds
      const res   = await fetch(
        `${FINNHUB_REST}/stock/candle?symbol=${sym}&resolution=5&from=${from}&to=${now}&token=${FINNHUB_KEY}`
      );
      const d = await res.json();
      if (d.s === 'ok' && d.c && d.c.length > 0) {
        data   = d.c; // close prices
        labels = d.t.map((ts, i) => {
          const dt = new Date(ts * 1000);
          const h  = dt.getHours(), m = dt.getMinutes();
          // Label every ~hour (every 12 × 5min candles)
          return (i % 12 === 0) ? `${h}:${m<10?'0':''}${m}` : '';
        });
        // Update last price in case WS hasn't fired yet
        if (data.length > 0) lastPrices[sym] = data[data.length - 1];
      }
    } catch(e) {}
  }

  // Fallback / non-1D periods: use seeded simulation anchored to live price
  if (!data) {
    const result = buildChartSeries(sym, base, period);
    data   = result.data;
    labels = result.labels;
  }

  const first = data[0], last = data[data.length - 1];
  const col   = last >= first ? '#00ffb3' : '#ff3d5a';

  mChart = new Chart(ctx, {
    type: 'line',
    data: {
      labels,
      datasets: [{
        data,
        borderColor: col,
        backgroundColor: col + '15',
        borderWidth: 1.5,
        fill: true,
        tension: 0.3,
        pointRadius: 0,
        pointHoverRadius: 4,
        pointHoverBackgroundColor: col,
        pointHoverBorderColor: '#020810',
      }]
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      animation: { duration: 250 },
      interaction: { mode: 'index', intersect: false },
      plugins: {
        legend: { display: false },
        tooltip: {
          backgroundColor: '#060e1c',
          borderColor: col + '44',
          borderWidth: 1,
          callbacks: {
            title: (items) => labels[items[0].dataIndex] || '',
            label: (c)    => ` $${parseFloat(c.raw).toFixed(2)}`
          }
        }
      },
      scales: {
        x: {
          grid: { display: false },
          ticks: { maxRotation: 0, font: { size: 9 }, color: '#3d6080' }
        },
        y: {
          grid: { color: 'rgba(0,200,255,0.05)' },
          ticks: { callback: v => `$${parseFloat(v).toFixed(0)}`, font: { size: 9 }, color: '#3d6080' },
          position: 'right'
        }
      }
    }
  });
}

