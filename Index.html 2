// Step 3: start sim loop as immediate fallback
// Step 4: fetch real quotes (updates lastPrices only, basePrices already locked)
// Step 5: open WebSocket for streaming
async function bootPriceEngine() {
  initPrices();           // lastPrices = hardcoded base values
  lockBasePrices();       // tentative basis = base values (shows $0 P&L immediately)
  buildTicker();
  updateTracker();
  setLiveStatus('sim');
  simInterval = setInterval(simTick, 1000);  // sim runs immediately

  // Fetch real quotes → lastPrices gets real prices
  const gotReal = await fetchAllQuotes();

  // NOW re-lock basis to real current prices so P&L starts at $0 vs real prices
  if (gotReal) lockBasePrices();

  // Open WebSocket for live streaming
  connectWebSocket();
}

